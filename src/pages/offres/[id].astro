---
import Layout from "../../layouts/Layout.astro";
import { getOffre, getImageUrl } from "../../backend.mjs";

const { id } = Astro.params;

const offre = await getOffre(id);

let imageUrl = null;

if (offre) {
    imageUrl = getImageUrl(offre, "images");
}
---

<Layout titre="Détail de l'offre">
    <div class="px-4 py-6 max-w-5xl mx-auto">
        <a
            href="/offres"
            class="inline-block mb-6 rounded-lg bg-slate-700 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800"
        >
            ← Retour aux offres
        </a>

        {
            offre ? (
                <>
                    {imageUrl && (
                        <img
                            src={imageUrl}
                            alt={offre.nomMaison}
                            class="w-full h-[420px] object-cover rounded-lg mb-6"
                        />
                    )}

                    <h1 class="text-3xl font-bold text-gray-900">
                        {offre.nomMaison}
                    </h1>

                    <p class="mt-3 text-xl font-semibold">{offre.prix} €</p>

                    <p class="mt-2 text-gray-600">{offre.adresse}</p>

                    <div class="mt-6 space-y-2 text-gray-700">
                        <p>
                            <strong>Chambres :</strong> {offre.nbChambres}
                        </p>
                        <p>
                            <strong>Salles de bain :</strong> {offre.nbSdb}
                        </p>
                        <p>
                            <strong>Surface :</strong> {offre.surface} m²
                        </p>
                        <p>
                            <strong>Favori :</strong>{" "}
                            {offre.favori ? "Oui" : "Non"}
                        </p>
                    </div>
                </>
            ) : (
                <p>Offre introuvable.</p>
            )
        }
    </div>
</Layout>

---
import PbImages from "./PbImages.astro";
const { offre } = Astro.props;
---

<article
	class="relative h-full flex flex-col rounded-lg border border-gray-200 bg-white p-4"
>
	<!-- COEUR FAVORI -->
	<button
		class="favoriteButton absolute top-2 right-2 p-2 bg-white rounded-full shadow"
		data-offre={JSON.stringify(offre)}
	>
		<img
			class="favorite-icon w-6 h-6"
			src={offre.favori ? "/favorite_filled.png" : "/favorite.png"}
			alt="Favori"
		/>
	</button>

	<h2 class="text-lg font-semibold">{offre.nomMaison}</h2>

	<div class="mt-4 h-64 w-full overflow-hidden rounded-md">
		<PbImages
			record={offre}
			imageField="images"
			width={400}
			height={500}
			class="w-full h-full object-cover"
		/>
	</div>

	<p class="mt-3 text-sm text-gray-600">{offre.adresse}</p>

	<p class="mt-2 text-sm">
		{offre.nbChambres} chambres • {offre.nbSdb} sdb • {offre.surface} m²
	</p>

	<p class="mt-2 mb-4 font-semibold">{offre.prix} €</p>

	<a
		href={`/offres/${offre.id}`}
		class="mt-auto rounded-lg bg-slate-700 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800 text-center"
	>
		Voir plus
	</a>
</article>

<script>
	//@ts-nocheck
	import { setFavori } from "../backend.mjs";

	const favoriteButtons = document.querySelectorAll(".favoriteButton");

	favoriteButtons.forEach((button) => {
		button.addEventListener("click", () => {
			const offreData = JSON.parse(button.dataset.offre || "{}");

			const newFavori = !offreData.favori;

			setFavori(offreData);

			const favIcon = button.querySelector(".favorite-icon");

			if (favIcon) {
				favIcon.src = newFavori
					? "/favorite_filled.png"
					: "/favorite.png";
			}

			offreData.favori = newFavori;

			button.dataset.offre = JSON.stringify(offreData);
		});
	});
</script>

---
import Layout from "../../layouts/Layout.astro";
import { getAgents } from "../../backend.mjs";

const agents = await getAgents();
---

<Layout titre="Agents">
    <div class="px-4 py-6">
        <h1 class="text-4xl font-bold text-gray-900 mt-2 mb-6">AGENTS</h1>

        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
            {
                agents.map((agent) => (
                    <article class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
                        <h2 class="text-xl font-semibold">
                            {agent.Prenom} {agent.Nom}
                        </h2>

                        <p class="mt-2 text-gray-600">{agent.email}</p>

                        <a
                            href={`/agents/${agent.id}`}
                            class="mt-4 inline-block rounded-lg bg-slate-700 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800"
                        >
                            Voir ses offres
                        </a>
                    </article>
                ))
            }
        </div>
    </div>
</Layout>

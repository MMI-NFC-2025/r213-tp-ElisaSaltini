---
import Layout from "../../layouts/Layout.astro";
import OffreCard from "../../components/OffreCard.astro";
import { getOffres, filterByPrix } from "../../backend.mjs";

let offres = [];
let message = "";

if (Astro.request.method === "POST") {
    const data = await Astro.request.formData();

    const minPrix = Number(data.get("minPrix"));
    const maxPrix = Number(data.get("maxPrix"));

    if (
        !isNaN(minPrix) &&
        !isNaN(maxPrix) &&
        minPrix >= 0 &&
        maxPrix >= 0 &&
        minPrix <= maxPrix
    ) {
        offres = await filterByPrix(minPrix, maxPrix);

        if (offres.length === 0) {
            message = `Aucune offre entre ${minPrix} € et ${maxPrix} €.`;
        } else {
            message = `${offres.length} offre(s) trouvée(s) entre ${minPrix} € et ${maxPrix} €.`;
        }
    } else {
        offres = await getOffres();
        message = "Veuillez entrer un prix minimum et un prix maximum valides.";
    }
} else {
    offres = await getOffres();
}
---

<Layout titre="Offres">
    <div class="px-4 py-6">
        <h1 class="mb-6 text-4xl font-bold text-gray-900">OFFRES</h1>

        <div
            class="mb-8 rounded-xl border border-gray-200 bg-white p-4 shadow-sm"
        >
            <div
                class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between"
            >
                <form
                    action="/offres"
                    method="POST"
                    class="flex flex-wrap items-center gap-3"
                >
                    <input
                        type="number"
                        name="minPrix"
                        placeholder="Prix minimum"
                        class="w-44 rounded-md border border-gray-300 px-3 py-2"
                    />

                    <input
                        type="number"
                        name="maxPrix"
                        placeholder="Prix maximum"
                        class="w-44 rounded-md border border-gray-300 px-3 py-2"
                    />

                    <input
                        type="submit"
                        value="Filtrer par prix"
                        class="rounded-md bg-slate-700 px-4 py-2 text-white hover:bg-slate-800"
                    />
                </form>

                <a
                    href="/offres/add"
                    class="w-fit rounded-lg bg-slate-700 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800"
                >
                    Ajouter une offre
                </a>
            </div>

            <div class="mt-4 flex flex-wrap items-center gap-3">
                <button
                    id="favori-button"
                    type="button"
                    class="rounded-lg bg-slate-700 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800"
                >
                    Afficher les favoris
                </button>

                <a
                    href="/offres/surface/80"
                    class="rounded-lg bg-slate-700 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800"
                >
                    Plus de 80 m²
                </a>

                <a
                    href="/offres/prix/3000"
                    class="rounded-lg bg-slate-700 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800"
                >
                    Moins de 3000 €
                </a>

                <a
                    href="/offres/prix/1500/300000000"
                    class="rounded-lg bg-slate-700 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800"
                >
                    Entre 1500 € et 300000000 €
                </a>
            </div>

            {message && <p class="mt-4 text-sm text-gray-700">{message}</p>}
        </div>

        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {
                offres.map((offre) => (
                    <div
                        class="offre"
                        data-favori={offre.favori ? "true" : "false"}
                    >
                        <OffreCard offre={offre} />
                    </div>
                ))
            }
        </div>
    </div>
</Layout>

<script>
    //@ts-nocheck
    const favoriButton = document.getElementById("favori-button");
    let favorisOnly = false;

    function updateAffichageFavoris() {
        const offres = document.querySelectorAll(".offre");

        offres.forEach((offre) => {
            const isFavori = offre.dataset.favori === "true";

            if (favorisOnly) {
                offre.style.display = isFavori ? "block" : "none";
            } else {
                offre.style.display = "block";
            }
        });

        if (favoriButton) {
            favoriButton.textContent = favorisOnly
                ? "Afficher tout"
                : "Afficher les favoris";
        }
    }

    favoriButton?.addEventListener("click", () => {
        favorisOnly = !favorisOnly;
        updateAffichageFavoris();
    });

    document.addEventListener("click", (event) => {
        const clickedButton = event.target.closest(".favoriteButton");
        if (!clickedButton) return;

        const wrapper = clickedButton.closest(".offre");
        if (!wrapper) return;

        const offreData = JSON.parse(clickedButton.dataset.offre || "{}");
        wrapper.dataset.favori = offreData.favori ? "true" : "false";

        if (favorisOnly) {
            updateAffichageFavoris();
        }
    });
</script>
